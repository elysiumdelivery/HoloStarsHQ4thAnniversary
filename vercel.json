{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/lobby", "destination": "/api/lobby.php" },
    { "source": "/hallway", "destination": "/api/hallway.php" },
    { "source": "/greenroom", "destination": "/api/greenroom.php" },
    { "source": "/altare", "destination": "/api/altare.php" },
    { "source": "/axel", "destination": "/api/axel.php" },
    { "source": "/staff", "destination": "/api/staff.php" },
    { "source": "/stage", "destination": "/api/stage.php" }
  ]
}