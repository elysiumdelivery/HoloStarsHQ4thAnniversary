{
  "version": 2,
  "functions": {
    "*.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/altare.php",
      "headers": { "Location": "/altare" },
      "status": 307
    },    {
      "src": "/axel.php",
      "headers": { "Location": "/axel" },
      "status": 307
    },
    {
      "src": "/greenroom.php",
      "headers": { "Location": "/greenroom" },
      "status": 307
    },
    {
      "src": "/hallway.php",
      "headers": { "Location": "/hallway" },
      "status": 307
    },
    {
      "src": "/lobby.php",
      "headers": { "Location": "/lobby" },
      "status": 307
    },
    {
      "src": "/staff.php",
      "headers": { "Location": "/staff" },
      "status": 307
    },
    {
      "src": "/stage.php",
      "headers": { "Location": "/stage" },
      "status": 307
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/public/(.*)",
      "dest": "/$1"
    }
  ]
}
