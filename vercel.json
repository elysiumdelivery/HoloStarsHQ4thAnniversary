{
  "version": 2,
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/altare",
      "dest": "/api/altare.php"
    },
    {
      "src": "/axel",
      "dest": "/api/axel.php"
    },
    {
      "src": "/greenroom",
      "dest": "/api/greenroom.php"
    },
    {
      "src": "/hallway",
      "dest": "/api/hallway.php"
    },
    {
      "src": "/lobby",
      "dest": "/api/lobby.php"
    },
    {
      "src": "/staff",
      "dest": "/api/staff.php"
    },
    {
      "src": "/stage",
      "dest": "/api/stage.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
